{
    "name": "drupal/cms",
    "description": "Drupal with a bunch of useful stuff.",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "homepage": "https://www.drupal.org/project/drupal",
    "support": {
        "docs": "https://drupal.org/docs/user_guide/en/index.html",
        "chat": "https://drupal.org/node/314178"
    },
    "repositories": {
        "accessibility_tools": {
            "type": "path",
